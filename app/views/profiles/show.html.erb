<section class="section-head">
  <h1>Profile</h1>
  <%= link_to "Edit Profile", edit_user_profile_path(@user), class: "btn btn-primary" %>
</section>

<section class="profile-card">
  <div class="profile-media">
    <% if @profile.profile_image.attached? %>
      <%= image_tag @profile.profile_image, alt: "#{@user.name} profile image" %>
    <% else %>
      <span>No Image</span>
    <% end %>
  </div>

  <div class="profile-content">
    <h2><%= @user.name %></h2>
    <p><strong>Email:</strong> <%= @user.email %></p>
    <p><strong>Phone:</strong> <%= @user.phone %></p>
    <p><strong>Gender:</strong> <%= @profile.gender.presence || "Not set" %></p>
    <p><strong>Date of Birth:</strong> <%= @profile.date_of_birth&.strftime("%d %b %Y") || "Not set" %></p>
    <p><strong>Address:</strong> <%= @profile.address.presence || "Not set" %></p>
    <p><strong>Bio:</strong> <%= @profile.bio %></p>
  </div>
</section>
