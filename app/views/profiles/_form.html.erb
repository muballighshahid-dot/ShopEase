<%= form_with model: @profile, url: user_profile_path(@user), local: true, html: { class: "profile-form" } do |f| %>
  <% if @profile.errors.any? %>
    <div class="error-messages">
      <% @profile.errors.full_messages.each do |message| %>
        <p><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :bio %>
    <%= f.text_area :bio, rows: 4, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :address %>
    <%= f.text_field :address, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :gender %>
    <%= f.select :gender, [["Male", "male"], ["Female", "female"], ["Other", "other"]], { include_blank: "Select" }, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :date_of_birth %>
    <%= f.date_field :date_of_birth, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :profile_image %>
    <%= f.file_field :profile_image, class: "form-control-file" %>
  </div>

  <div class="form-actions">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
