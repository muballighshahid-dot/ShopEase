<section class="section-head">
  <h1>Cart</h1>
  <%= link_to "Create Cart", new_cart_path, class: "btn btn-primary" %>
</section>

<% if @carts.any? %>
  <table class="data-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Status</th>
        <th>Total</th>
        <th>Items</th>
        <th>Product List</th>
        <th>Updated</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @carts.each do |cart| %>
        <tr>
          <td>#<%= cart.id %></td>
          <td><%= cart.status.presence || "active" %></td>
          <td>₹ <%= cart.total_price || 0 %></td>
          <td><%= cart.cart_items.sum(:quantity) %></td>
          <td>
            <% if cart.cart_items.any? %>
              <ul class="compact-list">
                <% cart.cart_items.each do |item| %>
                  <li>
                    <%= item.product.name %> x <%= item.quantity %>
                    <%= button_to "Remove", cart_cart_item_path(cart, item), method: :delete, class: "tiny-action" %>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <span class="no-image">No items</span>
            <% end %>
          </td>
          <td><%= cart.updated_at.strftime("%d %b %Y") %></td>
          <td>
            <%= link_to "Show", cart_path(cart) %>
            <%= link_to "Edit", edit_cart_path(cart) %>
            <% if cart.cart_items.any? %>
              <%= button_to "Place Order", place_from_cart_orders_path, method: :post, form: { data: { turbo_confirm: "Place order with these cart items?" } }, class: "btn btn-primary" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="empty-state">Your cart is empty right now.</p>
<% end %>
